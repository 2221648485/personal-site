---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const base = import.meta.env.BASE_URL.endsWith('/')
	? import.meta.env.BASE_URL
	: `${import.meta.env.BASE_URL}/`;
const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`文章 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="page-head">
				<p class="eyebrow">Archive</p>
				<h1>文章</h1>
				<p>这里会集中放置随笔、阶段总结、观察记录，以及少量技术整理。</p>
			</section>

			<section class="archive-list">
				{
					posts.map((post) => (
						<a class="archive-item" href={`${base}blog/${post.id}/`}>
							<div>
								<h2>{post.data.title}</h2>
								<p>{post.data.description}</p>
							</div>
							<p class="date">
								<FormattedDate date={post.data.pubDate} />
							</p>
						</a>
					))
				}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-head {
		margin: 1rem 0 1.4rem;
		padding: 2rem;
		border: 1px solid rgba(var(--border), 0.85);
		border-radius: 30px;
		background: rgba(var(--panel), 0.76);
		box-shadow: var(--shadow);
	}

	.eyebrow {
		margin-bottom: 0.8rem;
		font-size: 0.78rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: rgb(var(--muted));
	}

	.archive-list {
		display: grid;
		gap: 0.9rem;
	}

	.archive-item {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1rem;
		padding: 1.4rem 1.5rem;
		border: 1px solid rgba(var(--border), 0.85);
		border-radius: 24px;
		background: rgba(var(--panel), 0.72);
		color: inherit;
		text-decoration: none;
		transition:
			transform 180ms ease,
			border-color 180ms ease;
	}

	.archive-item:hover {
		transform: translateY(-3px);
		border-color: rgba(var(--accent), 0.36);
	}

	.archive-item h2 {
		margin-bottom: 0.45rem;
		font-size: 1.28rem;
	}

	.date {
		flex-shrink: 0;
		font-size: 0.92rem;
		white-space: nowrap;
	}

	@media (max-width: 720px) {
		.archive-item {
			flex-direction: column;
		}
	}
</style>
