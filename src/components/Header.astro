---
import { GITHUB_URL, SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

const base = import.meta.env.BASE_URL;
---

<header class="site-header">
	<nav>
		<div class="brand">
			<p class="eyebrow">Personal Site</p>
			<h2><a href={base}>{SITE_TITLE}</a></h2>
		</div>
		<div class="internal-links">
			<HeaderLink href={base}>首页</HeaderLink>
			<HeaderLink href={`${base}blog/`}>文章</HeaderLink>
			<HeaderLink href={`${base}about/`}>关于</HeaderLink>
		</div>
		<a class="github-link" href={GITHUB_URL} target="_blank" rel="noreferrer">GitHub</a>
	</nav>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 10;
		padding: 1rem 1.25rem 0;
		background: linear-gradient(180deg, rgba(246, 244, 239, 0.92), rgba(246, 244, 239, 0.7), transparent);
		backdrop-filter: blur(18px);
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		max-width: 1120px;
		margin: 0 auto;
		padding: 0.9rem 1rem;
		border: 1px solid rgba(var(--border), 0.8);
		border-radius: 24px;
		background: rgba(255, 255, 255, 0.72);
		box-shadow: 0 18px 40px rgba(35, 33, 28, 0.06);
	}

	.brand {
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
	}

	.eyebrow,
	h2 {
		margin: 0;
	}

	.eyebrow {
		font-size: 0.72rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: rgb(var(--muted));
	}

	h2 {
		font-size: 1rem;
		font-weight: 600;
	}

	h2 a {
		color: rgb(var(--ink));
		text-decoration: none;
	}

	.internal-links {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.github-link {
		padding: 0.72rem 1rem;
		border-radius: 999px;
		background: rgb(var(--panel-strong));
		color: rgb(var(--paper));
		text-decoration: none;
		font-size: 0.92rem;
	}

	.github-link:hover {
		background: rgb(var(--ink));
	}

	@media (max-width: 720px) {
		nav {
			flex-wrap: wrap;
			padding: 0.9rem;
		}

		.internal-links {
			order: 3;
			width: 100%;
			justify-content: space-between;
		}

		.github-link {
			margin-left: auto;
		}
	}
</style>
