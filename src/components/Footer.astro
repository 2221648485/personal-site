---
import { GITHUB_URL, SITE_AUTHOR, SITE_EMAIL, SITE_TITLE } from '../consts';

const today = new Date();
---

<footer>
	<div class="footer-inner">
		<div>
			<p class="footer-title">{SITE_TITLE}</p>
			<p class="footer-copy">
				&copy; {today.getFullYear()} {SITE_AUTHOR}。记录仍在继续，内容会慢慢长出来。
			</p>
		</div>
		<div class="footer-links">
			<a href={GITHUB_URL} target="_blank" rel="noreferrer">GitHub</a>
			<a href={`mailto:${SITE_EMAIL}`}>邮箱</a>
		</div>
	</div>
</footer>

<style>
	footer {
		padding: 2rem 1.25rem 4rem;
	}

	.footer-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		max-width: 1120px;
		margin: 0 auto;
		padding-top: 1.5rem;
		border-top: 1px solid rgba(var(--border), 0.9);
		color: rgb(var(--muted));
	}

	.footer-title,
	.footer-copy {
		margin: 0;
	}

	.footer-title {
		margin-bottom: 0.35rem;
		color: rgb(var(--ink));
		font-weight: 600;
	}

	.footer-links {
		display: flex;
		gap: 1rem;
	}

	.footer-links a {
		color: rgb(var(--muted));
		text-decoration: none;
	}

	.footer-links a:hover {
		color: rgb(var(--ink));
	}

	@media (max-width: 720px) {
		.footer-inner {
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>
