---
const base = import.meta.env.BASE_URL;
---

<aside class="side-mascots" aria-hidden="true">
	<img class="mascot mascot-left" src={`${base}bocchi-standee.svg`} alt="" loading="lazy" />
	<img class="mascot mascot-right" src={`${base}frieren-standee.svg`} alt="" loading="lazy" />
</aside>

<style>
	.side-mascots {
		display: none;
	}

	@media (min-width: 1280px) {
		.side-mascots {
			display: block;
		}

		.mascot {
			position: fixed;
			top: 118px;
			width: clamp(140px, 14vw, 220px);
			max-height: calc(100vh - 160px);
			object-fit: contain;
			pointer-events: none;
			user-select: none;
			opacity: 0.9;
			z-index: 2;
			filter: drop-shadow(0 18px 28px rgba(30, 34, 45, 0.14));
		}

		.mascot-left {
			left: clamp(8px, calc((100vw - 1120px) / 2 - 170px), 72px);
			transform: rotate(-3deg);
		}

		.mascot-right {
			right: clamp(8px, calc((100vw - 1120px) / 2 - 170px), 72px);
			transform: rotate(3deg);
		}
	}

	@media (min-width: 1280px) and (max-width: 1439px) {
		.mascot {
			width: 150px;
			opacity: 0.82;
		}
	}
</style>
