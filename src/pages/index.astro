---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import SideMascots from '../components/SideMascots.astro';
import {
	GITHUB_URL,
	HOME_INTRO,
	PROFILE_FACTS,
	SITE_AUTHOR,
	SITE_DESCRIPTION,
	SITE_TITLE,
} from '../consts';

const base = import.meta.env.BASE_URL;
const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<SideMascots />
		<main>
			<section class="hero">
				<div class="hero-copy">
					<p class="hero-label">中文个人主页 / 静态博客</p>
					<h1>{HOME_INTRO.title}</h1>
					<p class="hero-text">{HOME_INTRO.description}</p>
					<div class="hero-actions">
						<a class="primary-link" href={`${base}blog/`}>开始阅读</a>
						<a class="ghost-link" href={GITHUB_URL} target="_blank" rel="noreferrer">访问 GitHub</a>
					</div>
				</div>
				<div class="hero-card">
					<p class="card-kicker">关于站点</p>
					<h2>{SITE_AUTHOR}</h2>
					<p>
						这是一个围绕“小航”展开的长期空间。它不会被做成很标准的简历站，而是更接近一块持续更新的私人角落，慢慢放进研究、生活、写作和偶尔想认真记录的内容。
					</p>
					<ul>
						{PROFILE_FACTS.map((fact) => <li>{fact}</li>)}
					</ul>
				</div>
			</section>

			<section class="section-grid">
				<div class="section-heading">
					<p class="section-label">Now</p>
					<h2>最近在写什么</h2>
				</div>
				<div class="post-list">
					{
						posts.map((post) => (
							<a class="post-card" href={`${base}blog/${post.id}/`}>
								<p class="post-date">
									<FormattedDate date={post.data.pubDate} />
								</p>
								<h3>{post.data.title}</h3>
								<p>{post.data.description}</p>
							</a>
						))
					}
				</div>
			</section>

			<section class="notes-panel">
				<div>
					<p class="section-label dark">Positioning</p>
					<h2>研究生阶段，也可以有一块自己的缓冲地带。</h2>
				</div>
				<p>
					不把它做成纯项目展示页，也不把它做成冷冰冰的知识库。这里更像一个会慢慢长大的数字花园，用来放随笔、阶段总结、科研过程中的碎片思考，以及日常生活里那些值得留下来的小部分。
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1.3fr) minmax(280px, 0.8fr);
		gap: 1.25rem;
		align-items: stretch;
		margin-top: 1rem;
	}

	.hero-copy,
	.hero-card,
	.post-card,
	.notes-panel {
		border: 1px solid rgba(var(--border), 0.85);
		border-radius: 30px;
		background: rgba(var(--panel), 0.74);
		box-shadow: var(--shadow);
	}

	.hero-copy {
		padding: clamp(2rem, 5vw, 4rem);
	}

	.hero-label,
	.section-label,
	.card-kicker {
		margin-bottom: 1rem;
		font-size: 0.78rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: rgb(var(--muted));
	}

	.hero-text {
		max-width: 42rem;
		font-size: 1.08rem;
	}

	.hero-actions {
		display: flex;
		gap: 0.9rem;
		margin-top: 2rem;
	}

	.primary-link,
	.ghost-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.9rem 1.2rem;
		border-radius: 999px;
		text-decoration: none;
	}

	.primary-link {
		background: rgb(var(--panel-strong));
		color: rgb(var(--paper));
	}

	.ghost-link {
		border: 1px solid rgba(var(--border), 0.9);
		color: rgb(var(--ink));
	}

	.hero-card {
		padding: 1.75rem;
		background: linear-gradient(180deg, rgba(35, 38, 48, 0.98), rgba(28, 31, 39, 0.96));
	}

	.hero-card h2,
	.hero-card p,
	.hero-card li,
	.dark {
		color: rgba(255, 255, 255, 0.92);
	}

	.hero-card ul {
		margin: 1.5rem 0 0;
		padding-left: 1.1rem;
	}

	.hero-card li + li {
		margin-top: 0.6rem;
	}

	.section-grid {
		margin-top: 1.4rem;
	}

	.section-heading {
		margin-bottom: 1rem;
	}

	.post-list {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.post-card {
		padding: 1.4rem;
		color: inherit;
		text-decoration: none;
		transition:
			transform 180ms ease,
			border-color 180ms ease;
	}

	.post-card:hover {
		transform: translateY(-4px);
		border-color: rgba(var(--accent), 0.4);
	}

	.post-date {
		font-size: 0.9rem;
	}

	.post-card h3 {
		margin-bottom: 0.7rem;
		font-size: 1.2rem;
	}

	.notes-panel {
		display: grid;
		grid-template-columns: minmax(0, 0.8fr) minmax(0, 1fr);
		gap: 1rem;
		margin-top: 1.4rem;
		padding: 1.6rem;
	}

	@media (max-width: 900px) {
		.hero,
		.notes-panel,
		.post-list {
			grid-template-columns: 1fr;
		}
	}
</style>
