---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { GITHUB_URL, SITE_AUTHOR, SITE_DESCRIPTION, SITE_EMAIL, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`关于 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="about-panel">
				<p class="eyebrow">About</p>
				<h1>关于我</h1>
				<p>
					我是小航，目前在杭州电子科技大学读计算机方向研究生。这个页面暂时先放一个简洁版本，后面可以继续补充研究方向、项目、阅读兴趣和更完整的个人经历。
				</p>
				<hr />
				<div class="facts">
					<div>
						<h2>当前身份</h2>
						<p>{SITE_AUTHOR}，杭州电子科技大学计算机研究生。</p>
					</div>
					<div>
						<h2>这个站点想做什么</h2>
						<p>把研究生阶段零散的学习、生活和思考整理成可以长期积累的中文内容。</p>
					</div>
					<div>
						<h2>联系方式</h2>
						<p>邮箱：{SITE_EMAIL}</p>
						<p>
							GitHub：
							<a href={GITHUB_URL} target="_blank" rel="noreferrer">{GITHUB_URL}</a>
						</p>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.about-panel {
		margin-top: 1rem;
		padding: 2rem;
		border: 1px solid rgba(var(--border), 0.85);
		border-radius: 30px;
		background: rgba(var(--panel), 0.76);
		box-shadow: var(--shadow);
	}

	.eyebrow {
		margin-bottom: 0.8rem;
		font-size: 0.78rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: rgb(var(--muted));
	}

	.facts {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.facts h2 {
		font-size: 1.15rem;
	}

	@media (max-width: 900px) {
		.facts {
			grid-template-columns: 1fr;
		}
	}
</style>
