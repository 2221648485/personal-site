---
const base = import.meta.env.BASE_URL.endsWith('/')
	? import.meta.env.BASE_URL
	: `${import.meta.env.BASE_URL}/`;
---

<aside class="side-mascots" aria-hidden="true">
	<img
		class="mascot mascot-left"
		src={`${base}characters/bocchi.png`}
		alt=""
		loading="lazy"
	/>
	<img
		class="mascot mascot-right-top"
		src={`${base}characters/frieren-1.png`}
		alt=""
		loading="lazy"
	/>
	<img
		class="mascot mascot-right-bottom"
		src={`${base}characters/frieren-2.png`}
		alt=""
		loading="lazy"
	/>
</aside>

<style>
	.side-mascots {
		display: none;
	}

	@media (min-width: 1280px) {
		.side-mascots {
			display: block;
		}

		.mascot {
			position: fixed;
			width: clamp(140px, 14vw, 220px);
			max-height: calc(100vh - 160px);
			height: auto;
			object-fit: cover;
			object-position: center top;
			border-radius: 28px;
			pointer-events: none;
			user-select: none;
			opacity: 0.88;
			z-index: 2;
			border: 1px solid rgba(255, 255, 255, 0.7);
			box-shadow:
				0 22px 42px rgba(23, 28, 38, 0.16),
				0 0 0 10px rgba(255, 255, 255, 0.32);
		}

		.mascot-left {
			top: 118px;
			left: clamp(8px, calc((100vw - 1120px) / 2 - 170px), 72px);
			transform: rotate(-3deg);
		}

		.mascot-right-top {
			top: 96px;
			right: clamp(8px, calc((100vw - 1120px) / 2 - 170px), 72px);
			width: clamp(120px, 12vw, 180px);
			transform: rotate(3deg);
		}

		.mascot-right-bottom {
			right: clamp(12px, calc((100vw - 1120px) / 2 - 160px), 88px);
			bottom: 36px;
			width: clamp(150px, 15vw, 220px);
			transform: rotate(-2deg);
		}
	}

	@media (min-width: 1280px) and (max-width: 1439px) {
		.mascot {
			opacity: 0.82;
		}

		.mascot-left {
			width: 150px;
		}

		.mascot-right-top {
			width: 118px;
		}

		.mascot-right-bottom {
			width: 150px;
			bottom: 18px;
		}
	}
</style>
